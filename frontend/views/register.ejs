<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Registrazione</title>
  <link rel="stylesheet" href="views/css/register.css">
</head>
<body class="register-body">
  <h2>Register</h2>
  <form id="register-form" class="register-form" method="post">
    <input type="text" name="username" class="register-input" placeholder="Username" required>
    <input type="password" name="password" class="register-input" placeholder="Password" required>
    <button type="submit" class="register-button">Register</button>
  </form>
  <div id="registration-result" class="register-result"></div>
  <script src="views/js/register.js"></script>
</body>
</html>
